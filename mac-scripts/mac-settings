#!/usr/bin/env bash

set -euo pipefail

readonly GREEN='\033[0;32m'
readonly YELLOW='\033[0;33m'
readonly RED='\033[0;31m'
readonly BOLD='\033[1m'
readonly RESET='\033[0m'

log() { printf "${GREEN}✔${RESET} %s\n" "$*"; }
warn() { printf "${YELLOW}${BOLD}⚠${RESET} %s\n" "$*" >&2; }
die() {
  printf "${RED}${BOLD}✖${RESET} %s\n" "$*" >&2
  exit 1
}

readonly NOT_A_MAC_ERR="Not a Mac. Quitting."
[[ "$(uname)" == "Darwin" ]] || die "$NOT_A_MAC_ERR"

# Finder: show hidden files and filename extensions
log "Configuring Finder..."
defaults write com.apple.finder AppleShowAllFiles -bool true 2>/dev/null || {
  warn "Failed to show hidden files in Finder"
}
defaults write -g AppleShowAllExtensions -bool true 2>/dev/null || {
  warn "Failed to show filename extensions"
}
defaults write com.apple.finder FXDefaultSearchScope -string "SCcf" 2>/dev/null || {
  warn "Failed to set Finder search scope"
}
defaults write com.apple.desktopservices DSDontWriteNetworkStores -bool true 2>/dev/null || {
  warn "Failed to disable .DS_Store files on network drives"
}

# Disable natural scrolling for mouse
log "Setting mouse scrolling to normal..."
defaults write -g com.apple.swipescrolldirection -bool false 2>/dev/null || {
  warn "Failed to set mouse scrolling to normal"
}

log "Mouse scrolling is now normal."

# Trackpad: enable tap to click
log "Enabling tap to click..."
defaults write com.apple.AppleMultitouchTrackpad Clicking -bool true 2>/dev/null || {
  warn "Failed to enable tap to click for built-in trackpad"
}
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad Clicking -bool true 2>/dev/null || {
  warn "Failed to enable tap to click for bluetooth trackpad"
}
defaults write -g com.apple.mouse.tapBehavior -int 1 2>/dev/null || {
  warn "Failed to enable global tap to click"
}
defaults -currentHost write -g com.apple.mouse.tapBehavior -int 1 2>/dev/null || {
  warn "Failed to enable current-host tap to click"
}
log "Tap to click enabled."

# Keyboard: fast key repeat and short initial delay
log "Setting fast keyboard repeat..."
defaults write -g KeyRepeat -int 2 2>/dev/null || {
  warn "Failed to set key repeat"
}
defaults write -g InitialKeyRepeat -int 15 2>/dev/null || {
  warn "Failed to set initial key repeat"
}
log "Keyboard repeat configured."

# Screenshots: save to Pictures/Screenshots
log "Setting screenshot location..."
readonly SCREENSHOT_DIR="$HOME/Pictures/Screenshots"
mkdir -p "$SCREENSHOT_DIR"
defaults write com.apple.screencapture location -string "$SCREENSHOT_DIR" 2>/dev/null || {
  warn "Failed to set screenshot location"
}
killall SystemUIServer 2>/dev/null || true
log "Screenshot location configured."

# Set display scaling one step smaller than default
log "Setting display scaling one step smaller than default..."

if ! command -v displayplacer >/dev/null 2>&1; then
  brew install -q displayplacer 2>/dev/null || {
    warn "Failed to install displayplacer. Skipping display scaling."
  }
fi

# Dock: smallest size and enable magnify
log "Setting Dock to smallest size with magnify..."
defaults write com.apple.dock tilesize -int 16 2>/dev/null || {
  warn "Failed to set Dock tilesize"
}
defaults write com.apple.dock magnification -bool true 2>/dev/null || {
  warn "Failed to enable Dock magnification"
}
defaults write com.apple.dock autohide -bool true 2>/dev/null || {
  warn "Failed to enable Dock auto-hide"
}

# Text input: disable auto-correct
log "Disabling auto-correct..."
defaults write -g NSAutomaticSpellingCorrectionEnabled -bool false 2>/dev/null || {
  warn "Failed to disable auto-correct"
}
log "Auto-correct disabled."

# Dialogs: expand save and print panels by default
log "Expanding save and print dialogs by default..."
defaults write -g NSNavPanelExpandedStateForSaveMode -bool true 2>/dev/null || {
  warn "Failed to expand save dialogs"
}
defaults write -g NSNavPanelExpandedStateForSaveMode2 -bool true 2>/dev/null || {
  warn "Failed to expand save dialogs v2"
}
defaults write -g PMPrintingExpandedStateForPrint -bool true 2>/dev/null || {
  warn "Failed to expand print dialogs"
}
defaults write -g PMPrintingExpandedStateForPrint2 -bool true 2>/dev/null || {
  warn "Failed to expand print dialogs v2"
}
log "Save and print dialogs configured."
