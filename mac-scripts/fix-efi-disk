#!/usr/bin/env bash

if [ "$#" -ne 1 ]; then
  echo "Usage: $0 <vmid>"
  exit 1
fi

vmid="$1"
conf="/etc/pve/qemu-server/${vmid}.conf"

# Get zvol name
zvol=$(grep "^efidisk0:" "$conf" | grep -oP 'local-zfs:\K[^,]+')

echo "[$vmid] fixing efidisk: $zvol"

# Update config to efitype=2m
qm set "$vmid" -efidisk0 "local-zfs:${zvol},efitype=2m,pre-enrolled-keys=0,size=1M"

# Recreate zvol at correct size
zfs destroy "rpool/data/${zvol}"
zfs create -V 1M "rpool/data/${zvol}"

echo "[$vmid] done"
echo "---"
